{
  "ConnectionStrings": {
    "Default": "Data Source=kartelboats.db"
  },
  "Datalastic": {
    "ApiKey": "YOUR_DATALASTIC_API_KEY",
    "BaseUrl": "https://api.datalastic.com/api/v0"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "Model": "gpt-4o-mini"
  },
  "Cors": {
    "Origins": [
      "http://localhost:5500",
      "http://127.0.0.1:5500",
      "https://kartelboats.ru",
      "https://www.kartelboats.ru"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "KartelBoats.Api.Infrastructure.Services": "Information"
    }
  },
  "AllowedHosts": "*"
}
